{
  "name": "ai-grading-service",
  "version": "1.0.0",
  "description": "AI-powered returns grading microservice",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "generate:fixtures": "tsx tests/fixtures/images/generate-fixtures.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@fastify/multipart": "^8.3.0",
    "@google/generative-ai": "^0.21.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.1",
    "file-type": "^19.6.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "sharp": "^0.33.5",
    "sharp-phash": "^2.2.0",
    "@types/node": "^20.17.9",
    "typescript": "^5.7.2",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "aws-sdk-client-mock": "^4.1.0",
    "form-data": "^4.0.1",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
